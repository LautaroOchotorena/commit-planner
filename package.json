{
  "name": "commit-planner",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.1.4",
  "icon": "icon.png",
  "l10n": "./l10n",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "keywords": [
    "git",
    "commit",
    "commit planner",
    "planned commit",
    "snapshot",
    "working tree",
    "scm",
    "source control",
    "staging",
    "groups"
  ],
  "activationEvents": [
    "onView:commitPlanner.snapshots",
    "onCommand:commitPlanner.createSnapshot",
    "onCommand:commitPlanner.listSnapshots",
    "onCommand:commitPlanner.deactivateSnapshot"
  ],
  "extensionDependencies": [
    "vscode.git"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "commitPlanner.createSnapshot",
        "title": "%command.createSnapshot.title%",
        "category": "%command.category%",
        "icon": "$(save)"
      },
      {
        "command": "commitPlanner.listSnapshots",
        "title": "%command.listSnapshots.title%",
        "category": "%command.category%"
      },
      {
        "command": "commitPlanner.activateSnapshot",
        "title": "%command.activateSnapshot.title%",
        "category": "%command.category%",
        "icon": "$(play)"
      },
      {
        "command": "commitPlanner.deactivateSnapshot",
        "title": "%command.deactivateSnapshot.title%",
        "category": "%command.category%",
        "icon": "$(debug-step-out)"
      },
      {
        "command": "commitPlanner.deleteSnapshot",
        "title": "%command.deleteSnapshot.title%",
        "category": "%command.category%",
        "icon": "$(trash)"
      },
      {
        "command": "commitPlanner.renameSnapshot",
        "title": "%command.renameSnapshot.title%",
        "category": "%command.category%",
        "icon": "$(edit)"
      },
      {
        "command": "commitPlanner.compareFileWithSnapshot",
        "title": "%command.compareFileWithSnapshot.title%",
        "category": "%command.category%",
        "icon": "$(diff)"
      },
      {
        "command": "commitPlanner.openSnapshotFile",
        "title": "%command.openSnapshotFile.title%",
        "category": "%command.category%",
        "icon": "$(file)"
      },
      {
        "command": "commitPlanner.refresh",
        "title": "%command.refresh.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "commitPlanner.addGroup",
        "title": "%command.addGroup.title%",
        "category": "%command.category%",
        "icon": "$(git-commit)"
      },
      {
        "command": "commitPlanner.renameGroup",
        "title": "%command.renameGroup.title%",
        "category": "%command.category%",
        "icon": "$(edit)"
      },
      {
        "command": "commitPlanner.undoGroup",
        "title": "%command.undoGroup.title%",
        "category": "%command.category%",
        "icon": "$(discard)"
      },
      {
        "command": "commitPlanner.deleteGroupAndFiles",
        "title": "%command.deleteGroupAndFiles.title%",
        "category": "%command.category%",
        "icon": "$(trash)"
      },
      {
        "command": "commitPlanner.removeFileFromSnapshot",
        "title": "%command.removeFileFromSnapshot.title%",
        "category": "%command.category%",
        "icon": "$(close)"
      },
      {
        "command": "commitPlanner.assignFileToGroup",
        "title": "%command.assignFileToGroup.title%",
        "category": "%command.category%",
        "icon": "$(arrow-right)"
      },
      {
        "command": "commitPlanner.addFilesToGroup",
        "title": "%command.addFilesToGroup.title%",
        "category": "%command.category%",
        "icon": "$(add)"
      },
      {
        "command": "commitPlanner.stageGroupForCommit",
        "title": "%command.stageGroupForCommit.title%",
        "category": "%command.category%",
        "icon": "$(git-stash-apply)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "commitPlanner.snapshots",
          "name": "%view.snapshots.name%",
          "icon": "$(git-commit)",
          "contextualTitle": "%view.snapshots.contextualTitle%"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "commitPlanner.createSnapshot",
          "when": "view == commitPlanner.snapshots",
          "group": "navigation"
        },
        {
          "command": "commitPlanner.refresh",
          "when": "view == commitPlanner.snapshots",
          "group": "navigation"
        },
        {
          "command": "commitPlanner.deactivateSnapshot",
          "when": "view == commitPlanner.snapshots && commitPlanner.hasActiveSnapshot",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "commitPlanner.activateSnapshot",
          "when": "view == commitPlanner.snapshots && viewItem == snapshot",
          "group": "inline@1"
        },
        {
          "command": "commitPlanner.activateSnapshot",
          "when": "view == commitPlanner.snapshots && viewItem == snapshot",
          "group": "1_actions@1"
        },
        {
          "command": "commitPlanner.renameSnapshot",
          "when": "view == commitPlanner.snapshots && viewItem == snapshot",
          "group": "1_actions@2"
        },
        {
          "command": "commitPlanner.deleteSnapshot",
          "when": "view == commitPlanner.snapshots && viewItem == snapshot",
          "group": "1_actions@3"
        },
        {
          "command": "commitPlanner.addGroup",
          "when": "view == commitPlanner.snapshots && viewItem == snapshot",
          "group": "2_groups@1"
        },
        {
          "command": "commitPlanner.deactivateSnapshot",
          "when": "view == commitPlanner.snapshots && viewItem == activeSnapshot",
          "group": "inline@2"
        },
        {
          "command": "commitPlanner.deactivateSnapshot",
          "when": "view == commitPlanner.snapshots && viewItem == activeSnapshot",
          "group": "1_active@1"
        },
        {
          "command": "commitPlanner.stageGroupForCommit",
          "when": "view == commitPlanner.snapshots && viewItem == activeSnapshot",
          "group": "inline@3"
        },
        {
          "command": "commitPlanner.stageGroupForCommit",
          "when": "view == commitPlanner.snapshots && viewItem == activeSnapshot",
          "group": "1_scm@1"
        },
        {
          "command": "commitPlanner.stageGroupForCommit",
          "when": "view == commitPlanner.snapshots && viewItem == snapshotGroup",
          "group": "inline@1"
        },
        {
          "command": "commitPlanner.stageGroupForCommit",
          "when": "view == commitPlanner.snapshots && viewItem == snapshotGroup",
          "group": "1_scm@1"
        },
        {
          "command": "commitPlanner.renameGroup",
          "when": "view == commitPlanner.snapshots && viewItem == snapshotGroup",
          "group": "1_actions@1"
        },
        {
          "command": "commitPlanner.undoGroup",
          "when": "view == commitPlanner.snapshots && viewItem == snapshotGroup",
          "group": "1_actions@2"
        },
        {
          "command": "commitPlanner.deleteGroupAndFiles",
          "when": "view == commitPlanner.snapshots && viewItem == snapshotGroup",
          "group": "1_actions@3"
        },
        {
          "command": "commitPlanner.addFilesToGroup",
          "when": "view == commitPlanner.snapshots && viewItem == snapshotGroup",
          "group": "1_actions@4"
        },
        {
          "command": "commitPlanner.assignFileToGroup",
          "when": "view == commitPlanner.snapshots && viewItem == ungroupedGroup",
          "group": "1_actions@1"
        },
        {
          "command": "commitPlanner.stageGroupForCommit",
          "when": "view == commitPlanner.snapshots && viewItem == ungroupedGroup",
          "group": "inline@1"
        },
        {
          "command": "commitPlanner.stageGroupForCommit",
          "when": "view == commitPlanner.snapshots && viewItem == ungroupedGroup",
          "group": "1_scm@1"
        },
        {
          "command": "commitPlanner.compareFileWithSnapshot",
          "when": "view == commitPlanner.snapshots && viewItem == snapshotFile",
          "group": "1_actions@1"
        },
        {
          "command": "commitPlanner.openSnapshotFile",
          "when": "view == commitPlanner.snapshots && viewItem == snapshotFile",
          "group": "1_actions@2"
        },
        {
          "command": "commitPlanner.assignFileToGroup",
          "when": "view == commitPlanner.snapshots && viewItem == snapshotFile",
          "group": "1_actions@3"
        },
        {
          "command": "commitPlanner.removeFileFromSnapshot",
          "when": "view == commitPlanner.snapshots && viewItem == snapshotFile",
          "group": "1_actions@4"
        }
      ],
      "commandPalette": [
        {
          "command": "commitPlanner.activateSnapshot",
          "when": "false"
        },
        {
          "command": "commitPlanner.deleteSnapshot",
          "when": "false"
        },
        {
          "command": "commitPlanner.renameSnapshot",
          "when": "false"
        },
        {
          "command": "commitPlanner.compareFileWithSnapshot",
          "when": "false"
        },
        {
          "command": "commitPlanner.openSnapshotFile",
          "when": "false"
        },
        {
          "command": "commitPlanner.refresh",
          "when": "false"
        },
        {
          "command": "commitPlanner.addGroup",
          "when": "false"
        },
        {
          "command": "commitPlanner.renameGroup",
          "when": "false"
        },
        {
          "command": "commitPlanner.undoGroup",
          "when": "false"
        },
        {
          "command": "commitPlanner.deleteGroupAndFiles",
          "when": "false"
        },
        {
          "command": "commitPlanner.removeFileFromSnapshot",
          "when": "false"
        },
        {
          "command": "commitPlanner.assignFileToGroup",
          "when": "false"
        },
        {
          "command": "commitPlanner.addFilesToGroup",
          "when": "false"
        },
        {
          "command": "commitPlanner.stageGroupForCommit",
          "when": "false"
        },
        {
          "command": "commitPlanner.deactivateSnapshot",
          "when": "commitPlanner.hasActiveSnapshot"
        }
      ]
    },
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "commitPlanner.storageLocation": {
          "type": "string",
          "enum": [
            "workspaceStorage",
            "insideWorkspace"
          ],
          "enumDescriptions": [
            "%config.storageLocation.enumDescriptions.workspaceStorage%",
            "%config.storageLocation.enumDescriptions.insideWorkspace%"
          ],
          "default": "workspaceStorage",
          "description": "%config.storageLocation.description%"
        },
        "commitPlanner.blockActivationWithStagedChanges": {
          "type": "boolean",
          "default": true,
          "description": "%config.blockActivationWithStagedChanges.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "compile:test": "tsc -p ./test",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && npm run compile:test && node --test out/test/**/*.test.js",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.3.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LautaroOchotorena/commit-planner"
  },
  "publisher": "LautaroOchotorena",
  "license": "MIT"
}
