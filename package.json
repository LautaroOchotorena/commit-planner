{
  "name": "commit-planner",
  "displayName": "Commit Planner",
  "description": "Save planned commits as snapshots of selected working tree files. Activate to swap files temporarily, organize into colored groups, and stage each group for commit when ready.",
  "version": "0.1.0",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "keywords": [
    "git",
    "commit",
    "commit planner",
    "planned commit",
    "snapshot",
    "working tree",
    "scm",
    "source control",
    "staging",
    "groups"
  ],
  "activationEvents": [],
  "extensionDependencies": [
    "vscode.git"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "commitPlanner.createSnapshot",
        "title": "Create Planned Commit",
        "category": "Commit Planner",
        "icon": "$(save)"
      },
      {
        "command": "commitPlanner.listSnapshots",
        "title": "List Planned Commits",
        "category": "Commit Planner"
      },
      {
        "command": "commitPlanner.activateSnapshot",
        "title": "Activate",
        "category": "Commit Planner",
        "icon": "$(play)"
      },
      {
        "command": "commitPlanner.deactivateSnapshot",
        "title": "Deactivate",
        "category": "Commit Planner",
        "icon": "$(debug-step-out)"
      },
      {
        "command": "commitPlanner.deleteSnapshot",
        "title": "Delete",
        "category": "Commit Planner",
        "icon": "$(trash)"
      },
      {
        "command": "commitPlanner.renameSnapshot",
        "title": "Rename",
        "category": "Commit Planner",
        "icon": "$(edit)"
      },
      {
        "command": "commitPlanner.compareFileWithSnapshot",
        "title": "Compare File With Snapshot",
        "category": "Commit Planner",
        "icon": "$(diff)"
      },
      {
        "command": "commitPlanner.openSnapshotFile",
        "title": "Open Snapshot File",
        "category": "Commit Planner",
        "icon": "$(file)"
      },
      {
        "command": "commitPlanner.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "commitPlanner.addGroup",
        "title": "Add Group",
        "category": "Commit Planner",
        "icon": "$(git-commit)"
      },
      {
        "command": "commitPlanner.renameGroup",
        "title": "Rename Group",
        "category": "Commit Planner",
        "icon": "$(edit)"
      },
      {
        "command": "commitPlanner.deleteGroup",
        "title": "Delete Group",
        "category": "Commit Planner",
        "icon": "$(trash)"
      },
      {
        "command": "commitPlanner.assignFileToGroup",
        "title": "Move to Group",
        "category": "Commit Planner",
        "icon": "$(arrow-right)"
      },
      {
        "command": "commitPlanner.addFilesToGroup",
        "title": "Add Files to Group",
        "category": "Commit Planner",
        "icon": "$(add)"
      },
      {
        "command": "commitPlanner.stageGroupForCommit",
        "title": "Stage Group for Commit",
        "category": "Commit Planner",
        "icon": "$(git-stash-apply)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "commitPlanner.snapshots",
          "name": "Commit Planner",
          "icon": "$(git-commit)",
          "contextualTitle": "Commit Planner"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "commitPlanner.createSnapshot",
          "when": "view == commitPlanner.snapshots",
          "group": "navigation"
        },
        {
          "command": "commitPlanner.refresh",
          "when": "view == commitPlanner.snapshots",
          "group": "navigation"
        },
        {
          "command": "commitPlanner.deactivateSnapshot",
          "when": "view == commitPlanner.snapshots && commitPlanner.hasActiveSnapshot",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "commitPlanner.activateSnapshot",
          "when": "view == commitPlanner.snapshots && viewItem == snapshot",
          "group": "inline@1"
        },
        {
          "command": "commitPlanner.activateSnapshot",
          "when": "view == commitPlanner.snapshots && viewItem == snapshot",
          "group": "1_actions@1"
        },
        {
          "command": "commitPlanner.renameSnapshot",
          "when": "view == commitPlanner.snapshots && viewItem == snapshot",
          "group": "1_actions@2"
        },
        {
          "command": "commitPlanner.deleteSnapshot",
          "when": "view == commitPlanner.snapshots && viewItem == snapshot",
          "group": "1_actions@3"
        },
        {
          "command": "commitPlanner.addGroup",
          "when": "view == commitPlanner.snapshots && viewItem == snapshot",
          "group": "2_groups@1"
        },
        {
          "command": "commitPlanner.deactivateSnapshot",
          "when": "view == commitPlanner.snapshots && viewItem == activeSnapshot",
          "group": "inline@2"
        },
        {
          "command": "commitPlanner.deactivateSnapshot",
          "when": "view == commitPlanner.snapshots && viewItem == activeSnapshot",
          "group": "1_active@1"
        },
        {
          "command": "commitPlanner.stageGroupForCommit",
          "when": "view == commitPlanner.snapshots && viewItem == activeSnapshot",
          "group": "inline@3"
        },
        {
          "command": "commitPlanner.stageGroupForCommit",
          "when": "view == commitPlanner.snapshots && viewItem == activeSnapshot",
          "group": "1_scm@1"
        },
        {
          "command": "commitPlanner.stageGroupForCommit",
          "when": "view == commitPlanner.snapshots && viewItem == snapshotGroup",
          "group": "inline@1"
        },
        {
          "command": "commitPlanner.stageGroupForCommit",
          "when": "view == commitPlanner.snapshots && viewItem == snapshotGroup",
          "group": "1_scm@1"
        },
        {
          "command": "commitPlanner.renameGroup",
          "when": "view == commitPlanner.snapshots && viewItem == snapshotGroup",
          "group": "1_actions@1"
        },
        {
          "command": "commitPlanner.deleteGroup",
          "when": "view == commitPlanner.snapshots && viewItem == snapshotGroup",
          "group": "1_actions@2"
        },
        {
          "command": "commitPlanner.addFilesToGroup",
          "when": "view == commitPlanner.snapshots && viewItem == snapshotGroup",
          "group": "1_actions@3"
        },
        {
          "command": "commitPlanner.assignFileToGroup",
          "when": "view == commitPlanner.snapshots && viewItem == ungroupedGroup",
          "group": "1_actions@1"
        },
        {
          "command": "commitPlanner.stageGroupForCommit",
          "when": "view == commitPlanner.snapshots && viewItem == ungroupedGroup",
          "group": "inline@1"
        },
        {
          "command": "commitPlanner.stageGroupForCommit",
          "when": "view == commitPlanner.snapshots && viewItem == ungroupedGroup",
          "group": "1_scm@1"
        },
        {
          "command": "commitPlanner.compareFileWithSnapshot",
          "when": "view == commitPlanner.snapshots && viewItem == snapshotFile",
          "group": "1_actions@1"
        },
        {
          "command": "commitPlanner.openSnapshotFile",
          "when": "view == commitPlanner.snapshots && viewItem == snapshotFile",
          "group": "1_actions@2"
        },
        {
          "command": "commitPlanner.assignFileToGroup",
          "when": "view == commitPlanner.snapshots && viewItem == snapshotFile",
          "group": "1_actions@3"
        }
      ],
      "commandPalette": [
        {
          "command": "commitPlanner.activateSnapshot",
          "when": "false"
        },
        {
          "command": "commitPlanner.deleteSnapshot",
          "when": "false"
        },
        {
          "command": "commitPlanner.renameSnapshot",
          "when": "false"
        },
        {
          "command": "commitPlanner.compareFileWithSnapshot",
          "when": "false"
        },
        {
          "command": "commitPlanner.openSnapshotFile",
          "when": "false"
        },
        {
          "command": "commitPlanner.refresh",
          "when": "false"
        },
        {
          "command": "commitPlanner.addGroup",
          "when": "false"
        },
        {
          "command": "commitPlanner.renameGroup",
          "when": "false"
        },
        {
          "command": "commitPlanner.deleteGroup",
          "when": "false"
        },
        {
          "command": "commitPlanner.assignFileToGroup",
          "when": "false"
        },
        {
          "command": "commitPlanner.addFilesToGroup",
          "when": "false"
        },
        {
          "command": "commitPlanner.stageGroupForCommit",
          "when": "false"
        },
        {
          "command": "commitPlanner.deactivateSnapshot",
          "when": "commitPlanner.hasActiveSnapshot"
        }
      ]
    },
    "configuration": {
      "title": "Commit Planner",
      "properties": {
        "commitPlanner.storageLocation": {
          "type": "string",
          "enum": [
            "workspaceStorage",
            "insideWorkspace"
          ],
          "default": "workspaceStorage",
          "description": "Where to store snapshot data. 'workspaceStorage' uses VS Code's workspace storage (outside the repo). 'insideWorkspace' stores in .commit-planner/ at the workspace root."
        },
        "commitPlanner.blockActivationWithStagedChanges": {
          "type": "boolean",
          "default": true,
          "description": "Block snapshot activation when there are staged changes in Git."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "compile:test": "tsc -p ./test",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && npm run compile:test && node --test out/test/**/*.test.js",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.3.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LautaroOchotorena/commit-planner"
  },
  "publisher": "LautaroOchotorena",
  "license": "MIT"
}
